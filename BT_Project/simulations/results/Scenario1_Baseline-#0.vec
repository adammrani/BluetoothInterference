config *.slave3.mobility.typename StationaryMobility
config *.attacker1.mobility.typename StationaryMobility
config *.attacker2.mobility.typename StationaryMobility
config *.master.numApps 1
config *.master.app[0].typename UdpBasicApp
config *.master.app[0].destAddresses "\"slave1 slave2 slave3\""
config *.master.app[0].destPort 5000
config *.master.app[0].messageLength 200B
config *.master.app[0].sendInterval 0.02s
config *.slave1.numApps 1
config *.slave1.app[0].typename UdpSink
config *.slave1.app[0].localPort 5000
