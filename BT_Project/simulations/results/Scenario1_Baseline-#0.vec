config image-path ../../../Downloads/omnetpp-6.3.0-windows-x86_64/omnetpp-6.3.0/samples/inet4.6/images
config description "Baseline: normal piconet, no attacker active"
config *.attacker1.numApps 0
config *.attacker2.numApps 0
config network BluetoothNetwork
config *.**.wlan[0].radio.receiver.energyDetection -85dBm
config *.**.wlan[0].radio.receiver.sensitivity -85dBm
config sim-time-limit 60s
config **.scalar-recording true
config **.vector-recording true
config *.visualizer.*.displayCommunicationRange true
config *.visualizer.*.displayInterferenceRange true
config *.visualizer.*.displaySignals true
config *.radioMedium.typename RadioMedium
config *.radioMedium.communicationRange 15m
config *.radioMedium.interferenceRange 25m
config *.master.**.wlan[0].typename Ieee80211Interface
config *.master.**.wlan[0].radio.transmitter.power 1mW
config *.master.**.wlan[0].bitrate 2Mbps
config *.slave*.**.wlan[0].typename Ieee80211Interface
config *.slave*.**.wlan[0].radio.transmitter.power 1mW
config *.slave*.**.wlan[0].bitrate 2Mbps
config *.master.mobility.initialX 400m
config *.master.mobility.initialY 300m
config *.slave1.mobility.initialX 250m
config *.slave1.mobility.initialY 200m
config *.slave2.mobility.initialX 550m
config *.slave2.mobility.initialY 200m
config *.slave3.mobility.initialX 400m
config *.slave3.mobility.initialY 450m
config *.attacker1.mobility.initialX 150m
config *.attacker1.mobility.initialY 450m
config *.attacker2.mobility.initialX 650m
config *.attacker2.mobility.initialY 450m
config *.master.mobility.typename StationaryMobility
